<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gradient_start"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/emojiRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🃏🎮🃏"
        android:textSize="48sp" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Memory Flip"
        android:textColor="@color/white"
        android:textSize="40sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Choose your challenge"
        android:textColor="#CCFFFFFF"
        android:textSize="16sp" />

    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="#80FFFFFF" />

    <Button
        android:id="@+id/btn4x4"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/accent_purple"
        android:elevation="6dp"
        android:text="🟢  4 × 4 Grid  (Easy)"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn6x6"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:backgroundTint="@color/accent_orange"
        android:elevation="6dp"
        android:text="🔴  6 × 6 Grid  (Hard)"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Flip cards • Match pairs • Win!"
        android:textColor="#99FFFFFF"
        android:textSize="13sp" />

</LinearLayout>
